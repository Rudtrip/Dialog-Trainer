{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dialog-trainer.dev/schemas/scenario.schema.json",
  "title": "Dialog Trainer Scenario Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario",
    "steps",
    "choices",
    "endings",
    "scoring",
    "uiConfig"
  ],
  "properties": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "version", "locale", "startStepId"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "locale": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16
        },
        "startStepId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "authorId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{1,120}$"
            },
            "estimatedDurationSec": {
              "type": "integer",
              "minimum": 0
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 32
              },
              "maxItems": 50,
              "uniqueItems": true
            }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "choices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/choice"
      }
    },
    "endings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ending"
      }
    },
    "scoring": {
      "$ref": "#/$defs/scoring"
    },
    "uiConfig": {
      "$ref": "#/$defs/uiConfig"
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "type": {
          "type": "string",
          "enum": ["message", "question", "system"]
        },
        "speaker": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 80
        },
        "text": {
          "type": ["string", "null"],
          "maxLength": 4000
        },
        "mediaRef": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "choiceIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{1,120}$"
          },
          "uniqueItems": true
        },
        "uiOverrides": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "stepId", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "stepId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "nextStepId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "endingId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "scoreDelta": {
          "type": "integer",
          "minimum": -10000,
          "maximum": 10000
        },
        "feedback": {
          "type": ["string", "null"],
          "maxLength": 1000
        }
      },
      "oneOf": [
        { "required": ["nextStepId"] },
        { "required": ["endingId"] }
      ]
    },
    "ending": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,120}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": ["string", "null"],
          "maxLength": 2000
        },
        "scoreRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          }
        },
        "priority": {
          "type": "integer",
          "default": 0
        }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "maxScore", "passThreshold", "rules"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["sum", "weighted"]
        },
        "maxScore": {
          "type": "integer",
          "minimum": 0
        },
        "passThreshold": {
          "type": "integer",
          "minimum": 0
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "when"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{1,120}$"
              },
              "when": {
                "type": "object",
                "additionalProperties": true
              },
              "add": {
                "type": "integer"
              },
              "cap": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "uiConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theme", "colors", "layout", "branding"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["light"]
        },
        "colors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "background", "text"],
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^#([A-Fa-f0-9]{6})$"
            },
            "background": {
              "type": "string",
              "pattern": "^#([A-Fa-f0-9]{6})$"
            },
            "text": {
              "type": "string",
              "pattern": "^#([A-Fa-f0-9]{6})$"
            }
          }
        },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "showAvatar", "showProgress"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["chat", "cards"]
            },
            "showAvatar": {
              "type": "boolean"
            },
            "showProgress": {
              "type": "boolean"
            }
          }
        },
        "branding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["courseTitle"],
          "properties": {
            "logoUrl": {
              "type": "string",
              "format": "uri",
              "maxLength": 2048
            },
            "courseTitle": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          }
        }
      }
    }
  }
}
