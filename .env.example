PORT=3000
SUPABASE_URL=https://lxxohuudmdcvmjrxhdev.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
PLAYER_BASE_URL=https://player.dialog-trainer.local

# Required for Supabase CLI operations like `supabase link` and `supabase db push`.
SUPABASE_ACCESS_TOKEN=REPLACE_WITH_PERSONAL_ACCESS_TOKEN

# Optional for server-side operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# S3 media settings (optional for MVP).
# If these are not set, asset uploads are stored locally under /public/uploads/library-assets.
AWS_REGION=us-east-1
S3_BUCKET=dialog-trainer-media-dev
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME

# Asset upload limits and signed URL lifetime
ASSET_CHARACTER_MAX_BYTES=2097152
ASSET_BACKGROUND_MAX_BYTES=1048576
ASSET_SIGNED_URL_TTL_SEC=3600
LOCAL_ASSET_PREFIX=uploads/library-assets
